  // ============================================================
    //  Jenkinsfile — Pipeline Node.js con SonarQube + Trivy
    //  Coloca este archivo en la raíz de tu proyecto
    // ============================================================
    //
  //  Plugins de Jenkins necesarios (instalar desde UI):
    //    - SonarQube Scanner
    //    - NodeJS Plugin
    //    - Docker Pipeline
    //    - Pipeline (ya viene por defecto)
    //
  //  Configuración previa en Jenkins UI:
    //    Manage Jenkins → System → SonarQube servers
  //      Name: sonarqube-local
  //      URL:  http://devsecops_sonarqube:9000   (nombre del container)
  //      Token: (generar en SonarQube → My Account → Security)

    pipeline {
    agent any

  // Polling: Jenkins revisa GitHub cada 5 minutos
    // No necesitas webhooks ni IP pública
    triggers {
    pollSCM('H/5 * * * *')
  }

    tools {
    nodejs 'node24'   // configurar en Manage Jenkins → Tools → NodeJS
  }

    environment {
    // Nombre del proyecto en SonarQube (crearlo primero en localhost:9000)
    SONAR_PROJECT_KEY = 'personal'
    SONAR_PROJECT_NAME = 'banking-api'

    // Imagen Docker de tu app (para que Trivy la escanee)
    DOCKER_IMAGE = 'mi-app-node:latest'
  }

    stages {

    stage('Checkout') {
    steps {
    checkout scm
  echo "Rama: ${env.BRANCH_NAME} — Commit: ${env.GIT_COMMIT?.take(7)}"
  }
  }

    stage('Install dependencies') {
    steps {
    sh 'npm ci'
  }
  }

    stage('Tests') {
    steps {
    sh 'npm test -- --coverage'
  }
    post {
    always {
    // Publica resultados de cobertura si usas Jest
    publishHTML([
  allowMissing: true,
  reportDir: 'coverage/lcov-report',
  reportFiles: 'index.html',
  reportName: 'Coverage Report'
  ])
  }
  }
  }

    stage('SonarQube Analysis') {
    steps {
    withSonarQubeEnv('sonarqube-local') {
    sh """
    npx sonar-scanner \
    -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
    -Dsonar.projectName="${SONAR_PROJECT_NAME}" \
    -Dsonar.sources=src \
    -Dsonar.tests=src \
    -Dsonar.test.inclusions=**/*.spec.ts,**/*.test.ts \
    -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
    -Dsonar.host.url=http://devsecops_sonarqube:9000
    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                // Espera a que SonarQube procese y valida que pasó
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Trivy — Filesystem Scan') {
            steps {
                // Escanea dependencias y archivos del proyecto
                sh """
    docker run --rm \
    -v \$(pwd):/scan:ro \
    -v ~/.cache/trivy:/root/.cache/trivy \
    aquasec/trivy:latest fs \
    --exit-code 0 \
    --severity HIGH,CRITICAL \
    --format table \
    /scan
    """
                // --exit-code 0: no falla el pipeline (cambiar a 1 si quieres que falle en CRITICAL)
            }
        }

        stage('Trivy — Image Scan') {
            // Solo corre si tu proyecto tiene Dockerfile
            when {
                expression { fileExists('Dockerfile') }
            }
            steps {
                sh "docker build -t ${DOCKER_IMAGE} ."
    sh """
    docker run --rm \
    -v /var/run/docker.sock:/var/run/docker.sock \
    -v ~/.cache/trivy:/root/.cache/trivy \
    aquasec/trivy:latest image \
    --exit-code 0 \
    --severity HIGH,CRITICAL \
    --format table \
    ${DOCKER_IMAGE}
    """
  }
  }
  }

    post {
    success {
    echo '✅ Pipeline completado — sin issues críticos'
  }
    failure {
    echo '❌ Pipeline falló — revisa SonarQube en http://localhost:9000'
  }
    always {
    cleanWs()   // limpia workspace al terminar
  }
  }
  }
