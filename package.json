{
  "name": "banking-api",
  "version": "1.0.0",
  "description": "Banking REST API - Koa.js + TypeScript + PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@koa/router": "^12.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "nodemon": "^3.1.4",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "is-generator-function": "1.0.10"
    }
  }
}
